{
  "openapi": "3.0.3",
  "info": {
    "title": "Education Service API",
    "description": "API для управления прогрессом обучения и задачами",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API v1"
    }
  ],
  "paths": {
    "/me/progress": {
      "post": {
        "summary": "Создать прогресс",
        "description": "Создает запись о прогрессе пользователя по указанному slug",
        "operationId": "createProgress",
        "tags": ["Progress"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetProgressRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Прогресс успешно создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProgressResponse"
                }
              }
            }
          },
          "400": {
            "description": "Неверный запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Прогресс уже существует",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Внутренняя ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Список прогресса пользователя",
        "description": "Возвращает список прогресса текущего пользователя с пагинацией",
        "operationId": "listMyProgress",
        "tags": ["Progress"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Количество записей на странице",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Смещение для пагинации",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешный ответ",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProgressResponseList"
                }
              }
            }
          },
          "400": {
            "description": "Неверный запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Внутренняя ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/problems": {
      "post": {
        "summary": "Создать задачу",
        "description": "Создает новую задачу",
        "operationId": "createProblem",
        "tags": ["Problems"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Задача успешно создана"
          },
          "400": {
            "description": "Неверный запрос"
          },
          "401": {
            "description": "Не авторизован"
          },
          "500": {
            "description": "Внутренняя ошибка сервера"
          }
        }
      },
      "get": {
        "summary": "Список задач",
        "description": "Возвращает список задач с возможностью фильтрации",
        "operationId": "listProblems",
        "tags": ["Problems"],
        "responses": {
          "200": {
            "description": "Успешный ответ"
          },
          "400": {
            "description": "Неверный запрос"
          },
          "401": {
            "description": "Не авторизован"
          },
          "500": {
            "description": "Внутренняя ошибка сервера"
          }
        }
      }
    },
    "/problems/{slug}": {
      "put": {
        "summary": "Обновить задачу",
        "description": "Обновляет существующую задачу по slug",
        "operationId": "updateProblem",
        "tags": ["Problems"],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "Slug задачи",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Задача успешно обновлена"
          },
          "400": {
            "description": "Неверный запрос"
          },
          "401": {
            "description": "Не авторизован"
          },
          "404": {
            "description": "Задача не найдена"
          },
          "500": {
            "description": "Внутренняя ошибка сервера"
          }
        }
      },
      "delete": {
        "summary": "Удалить задачу",
        "description": "Удаляет задачу по slug",
        "operationId": "deleteProblem",
        "tags": ["Problems"],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "Slug задачи",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Задача успешно удалена"
          },
          "400": {
            "description": "Неверный запрос"
          },
          "401": {
            "description": "Не авторизован"
          },
          "404": {
            "description": "Задача не найдена"
          },
          "500": {
            "description": "Внутренняя ошибка сервера"
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Проверка здоровья сервиса",
        "description": "Возвращает статус сервиса",
        "operationId": "healthCheck",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "Сервис работает"
          },
          "500": {
            "description": "Сервис не работает"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SetProgressRequest": {
        "type": "object",
        "required": ["slug"],
        "properties": {
          "slug": {
            "type": "string",
            "description": "Slug задачи или урока"
          }
        }
      },
      "ProgressResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Уникальный идентификатор прогресса"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "Идентификатор пользователя"
          },
          "slug": {
            "type": "string",
            "description": "Slug задачи или урока"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Дата создания"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Дата последнего обновления"
          }
        }
      },
      "ProgressResponseList": {
        "type": "object",
        "properties": {
          "progress_list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProgressResponse"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Сообщение об ошибке"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT токен авторизации"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
